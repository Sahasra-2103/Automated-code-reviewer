PORT=5000
MONGODB_URI=your_mongodb_connection_string

# Choose ONE AI provider: 'groq' or 'grok' (X.AI)
# For Groq (recommended):
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

